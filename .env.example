# QueueStorm Investigator — environment variables
# Copy this file to `.env` (or set vars in your platform's dashboard) and fill values.
# The deterministic path runs without ANY of these set; only the optional LLM
# polish layer needs LLM_* values.

# --- Required for deterministic path ---
# (none — service runs with zero env vars)

# --- Optional LLM polish layer ---
# Set to "true" to enable. When false or unset, the deterministic engine is the
# entire response. Any LLM timeout, parse error, or unsafe rewrite falls back
# silently to the deterministic output.
USE_LLM=false

# Provider id (informational; the code is OpenAI-compatible). Examples:
#   openai | anthropic | openrouter | custom
LLM_PROVIDER=

# OpenAI-compatible chat completions endpoint (e.g. https://api.openai.com/v1/chat/completions).
# Required when USE_LLM=true. Leave empty to disable the polish layer.
LLM_BASE_URL=

# API key for the provider above. NEVER commit a real value. Use the deployment
# platform's secret store (Render env, Railway secret, Fly secret, etc).
LLM_API_KEY=

# Model name passed to the provider. Default: gpt-4o-mini.
LLM_MODEL=gpt-4o-mini

# Hard timeout for the LLM call in seconds. Spec §9 enforces a 30s per-request
# budget; 8s leaves headroom for the rest of the pipeline. Anything longer is
# still capped by FastAPI's request timeout.
LLM_TIMEOUT_SECONDS=8

# --- Server ---
# Port the API binds to. Honored by both uvicorn (local) and the Dockerfile/Render.
PORT=8000
